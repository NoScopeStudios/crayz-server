# CrayZ deployment environment file.
# Copy this to .env in your deployment folder and adjust locally.
# Do NOT commit .env.

DAYZ_SERVER_NAME=CrayZ Test Server
DAYZ_SERVER_PORT=2302
DAYZ_STEAM_QUERY_PORT=27016
DAYZ_SERVER_CONFIG=serverDZ.cfg
DAYZ_STEAM_APP_ID=223350
DAYZ_VALIDATE_INSTALL=1
DAYZ_AUTO_UPDATE=1
DAYZ_EXTRA_ARGS=

# First-run seeding:
# The container creates config/serverDZ.cfg and config/mods.txt if they are missing.
# Existing files are preserved and never overwritten by the entrypoint.

# First SteamCMD login:
# 1. Fill STEAM_USERNAME and STEAM_PASSWORD in .env.
# 2. Fill STEAM_GUARD_CODE only when Steam Guard asks for it.
# 3. Set DAYZ_ALLOW_STEAM_CREDENTIAL_LOGIN=1 in .env.
# 4. After the first successful login, clear STEAM_GUARD_CODE in .env.
#
# A normal Steam account login is required for SteamCMD.
# Anonymous SteamCMD login is intentionally unsupported for CrayZ.
# Keep values empty in this example; set them only in your local .env.
STEAM_USERNAME=
STEAM_PASSWORD=
STEAM_GUARD_CODE=
# Change this to 1 only in your local .env after setting credentials.
DAYZ_ALLOW_STEAM_CREDENTIAL_LOGIN=0
