# CrayZ example environment file.
# Copy this to .env and adjust locally.
# Do NOT commit .env.

DAYZ_SERVER_NAME=CrayZ Test Server
DAYZ_SERVER_PORT=2302
DAYZ_STEAM_QUERY_PORT=27016
DAYZ_SERVER_CONFIG=serverDZ.cfg
DAYZ_STEAM_APP_ID=223350
DAYZ_VALIDATE_INSTALL=1
DAYZ_AUTO_UPDATE=1
DAYZ_EXTRA_ARGS=

# Steam credentials should not be committed.
# Credentialed SteamCMD login still needs validation. Keep these empty for
# the default vanilla lab path, which uses anonymous SteamCMD login.
STEAM_USERNAME=
STEAM_PASSWORD=
STEAM_GUARD_CODE=
DAYZ_ALLOW_STEAM_CREDENTIAL_LOGIN=0
