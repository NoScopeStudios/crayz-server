# CrayZ example environment file.
# Copy this to .env for normal Compose usage, or to crayz.env when using an
# OMV-style named stack with `docker compose -f crayz.yml --env-file crayz.env`.
# Do NOT commit .env, crayz.env, or any file containing real credentials.

DAYZ_SERVER_NAME=CrayZ Test Server
DAYZ_SERVER_PORT=2302
DAYZ_STEAM_QUERY_PORT=27016
DAYZ_SERVER_CONFIG=serverDZ.cfg
DAYZ_STEAM_APP_ID=223350
DAYZ_WORKSHOP_APP_ID=221100
DAYZ_VALIDATE_INSTALL=1
DAYZ_AUTO_UPDATE=1
DAYZ_EXTRA_ARGS=

# Linux host ownership for bind-mounted files.
# On OMV/Linux, run `id yourusername` and set these to that user's uid/gid.
PUID=1000
PGID=1000

# First SteamCMD login:
# 1. Copy this file to .env.
# 2. Fill STEAM_USERNAME and STEAM_PASSWORD in .env.
# 3. Fill STEAM_GUARD_CODE only when Steam Guard asks for it.
# 4. Set DAYZ_ALLOW_STEAM_CREDENTIAL_LOGIN=1 in .env.
# 5. After the first successful login, clear STEAM_GUARD_CODE in .env.
#
# A normal Steam account login is required for SteamCMD.
# Anonymous SteamCMD login is intentionally unsupported for CrayZ.
# Keep values empty in this example; set them only in your local .env.
STEAM_USERNAME=
STEAM_PASSWORD=
STEAM_GUARD_CODE=
# Default is 1 because CrayZ requires credentialed SteamCMD login.
# Set to 0 only when intentionally testing startup/config generation without Steam login.
DAYZ_ALLOW_STEAM_CREDENTIAL_LOGIN=1
