# CrayZ example environment file.
# Copy this to .env and adjust locally.
# Do NOT commit .env.

DAYZ_SERVER_NAME=CrayZ Test Server
DAYZ_SERVER_PORT=2302
DAYZ_STEAM_QUERY_PORT=27016
DAYZ_SERVER_CONFIG=serverDZ.cfg
DAYZ_STEAM_APP_ID=223350
DAYZ_VALIDATE_INSTALL=1
DAYZ_AUTO_UPDATE=1
DAYZ_EXTRA_ARGS=

# A normal Steam account login is required for SteamCMD.
# Anonymous SteamCMD login is intentionally unsupported for CrayZ.
# Keep values empty in this example; set them only in your local .env.
STEAM_USERNAME=
STEAM_PASSWORD=
STEAM_GUARD_CODE=
# Change this to 1 only in your local .env after setting credentials.
DAYZ_ALLOW_STEAM_CREDENTIAL_LOGIN=0
